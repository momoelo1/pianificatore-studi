PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/studyplanner?retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-string
# Allowed CORS origin(s) — scheme + host only, NO path. Comma-separate several.
# GitHub Pages origin is just the user domain (the project path is ignored by CORS).
FRONTEND_URL=https://yourusername.github.io
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
